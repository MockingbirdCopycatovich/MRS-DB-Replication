{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Docker": {
    "SocketPath": "unix:///var/run/docker.sock",
    "NetworkName": "mrs-net",
    "Image": "mrs-postgres-node:latest",
    "PrimaryContainerName": "mrs-postgres-primary",
    "PrimaryHostPort": 5432,
    "ReplicaHostPortRangeStart": 5433,
    "InternalPostgresPort": 5432,
    "ReconcileIntervalSeconds": 10
  },
  "Postgres": {
    "User": "mrs_user",
    "Password": "mrs_password",
    "Database": "mrs_db"
  },
  "Watchdog": {
    "BaseUrl": "http://watchdog:8080"
  }
}
